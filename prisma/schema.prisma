generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  role      String   @default("SALES")
  createdAt DateTime @default(now())
}

model Car {
  id          Int      @id @default(autoincrement())
  brand       String
  model       String
  type        String
  transmisi   String
  year        Int
  color       String
  price       Float
  plateNumber String?
  description String?
  status      String   @default("READY")
  media       CarMedia[] // relasi ke tabel media
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Tabel baru untuk menyimpan foto dan video
model CarMedia {
  id           Int      @id @default(autoincrement())
  carId        Int      
  car          Car      @relation(fields: [carId], references: [id], onDelete: Cascade)
  url          String   // path file
  type         String   // "image" atau "video"
  createdAt    DateTime @default(now())

  @@map("car_media")
}